{
  "manifest_version": 3,
  "name": "__MSG_plugin_name__",
  "version": "1.0",
  "description": "__MSG_plugin_desc__",
  "default_locale": "zh_CN",
  "permissions": [
    "bookmarks"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_action_title__",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}